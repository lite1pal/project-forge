{
  "name": "@auditrail/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm validate:env && tsc -p tsconfig.json",
    "start": "pnpm validate:env && node dist/server.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "validate:env": "tsx src/validate-env.ts"
  },
  "dependencies": {
    "@auditrail/db": "workspace:*",
    "@auditrail/domain": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.15.6",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
