---
import { Image } from 'astro:assets';
import dashboard from '../assets/images/dashboard.jpg';
---

<section
  class="bg-bgDark1 mb-[28vw] flex w-full items-center justify-center pb-24 sm:pb-32 md:mb-[18vw] md:pb-44 lg:mb-[10vw] lg:pb-0 xl:mb-[13vw] 2xl:mb-60"
  id="home"
>
  <div
    class="flex w-full flex-col items-center justify-center pt-16 text-center md:w-[50rem] md:pt-16 lg:pt-20 xl:w-[56.25rem]"
  >
    <div class="hero-fade-in" style="--delay: 0s">
      <span class="block-subtitle mt-16 mb-6 block text-[0.65rem] sm:mt-32 sm:text-xs">
        AI-native platform framework
      </span>
    </div>
    <div class="hero-fade-in mx-auto max-w-3xl px-4" style="--delay: 0.05s">
      <h1
        class="xs:text-4xl text-[1.7rem] leading-[1.1] font-bold tracking-tight md:text-5xl lg:text-6xl"
      >
        <span class="text-heroText">Build production-ready</span><br />
        <span class="text-heroText">platforms, not starter kits</span>
      </h1>
    </div>
    <div class="hero-fade-in" style="--delay: 0.1s">
      <p
        class="text-secondaryText mx-auto mt-7 max-w-2xl px-4 text-sm leading-relaxed sm:text-base"
      >
        Build new platform features in minutes instead of days. Generate schemas, APIs, database
        migrations, tests, and documentation while keeping your architecture clean.
      </p>
    </div>
    <div class="hero-fade-in" style="--delay: 0.15s">
      <div class="mt-10 mb-24 flex flex-col justify-center gap-2 sm:mb-40 sm:flex-row">
        <a
          class="contained-button mr-0 mb-2 flex h-12 w-72 items-center justify-center text-sm transition-all duration-300 hover:shadow-[0_0_30px_rgba(99,102,241,0.25)] sm:mr-2 sm:mb-0 sm:w-44 lg:mr-3"
          href="https://github.com/lite1pal/elioric"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open the Elioric repository"
        >
          Explore the repo
        </a>
        <a
          class="text-primaryText bg-bgDark2 hover:bg-bgDark3 border-primaryColor flex h-12 w-72 cursor-pointer items-center justify-center rounded-xl border border-solid text-sm font-bold transition sm:w-44"
          href="#proof"
          aria-label="Jump to proof points"
        >
          See the workflow
        </a>
      </div>
    </div>
    <div class="relative z-20 flex w-screen justify-center">
      <div
        class="hero-fade-in image-glow-border absolute z-10 mx-auto w-11/12 rounded-2xl lg:top-6 xl:top-0 xl:w-5/6 2xl:w-[75rem]"
        style="--delay: 0.15s; opacity: 0.005"
      >
        <div class="main-border-gray rounded-2xl bg-white shadow-2xl">
          <div class="grid overflow-hidden rounded-2xl lg:grid-cols-[0.95fr_1.05fr]">
            <div
              class="border-mainBorderSubtler border-b bg-gray-950 p-5 text-left lg:border-r lg:border-b-0"
            >
              <div class="mb-5 flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-red-400"></span>
                <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
                <span class="h-3 w-3 rounded-full bg-green-400"></span>
                <span class="ml-3 text-xs text-gray-400">terminal</span>
              </div>

              <pre
                class="overflow-x-auto text-sm leading-7 text-gray-100"><code>$ pnpm saas init resource project
$ pnpm saas plan resources/project.json
$ pnpm saas preview resources/project.json
$ pnpm saas install resources/project.json

✓ schema generated
✓ domain contracts written
✓ API routes installed
✓ docs updated
✓ verification passed</code></pre>
            </div>

            <div class="bg-bgDark1 p-5 text-left">
              <div class="mb-4 flex items-center justify-between">
                <p class="text-primaryText text-sm font-semibold">
                  One command generates everything you need
                </p>
                <span class="badge-primary">Production-ready output</span>
              </div>

              <div class="space-y-3">
                <div class="card p-4">
                  <p class="text-primaryText text-sm font-semibold">Business logic</p>
                  <p class="text-secondaryText mt-1 text-sm">
                    Your application's rules stay isolated from infrastructure.
                  </p>
                </div>

                <div class="card p-4">
                  <p class="text-primaryText text-sm font-semibold">Backend</p>
                  <p class="text-secondaryText mt-1 text-sm">
                    Database, API routes, migrations, repositories, and services are generated
                    together.
                  </p>
                </div>

                <div class="card p-4">
                  <p class="text-primaryText text-sm font-semibold">Quality</p>
                  <p class="text-secondaryText mt-1 text-sm">
                    Tests, documentation, and architecture checks are updated automatically.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="relative flex w-screen justify-center">
      <div class="shape-divider-bottom-1665343298 mt-4 hidden sm:mt-16 md:mt-52 lg:block">
        <svg
          data-name="Layer 1"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 1200 120"
          preserveAspectRatio="none"
          class="bg-bgDark2"
          aria-hidden="true"
        >
          <path d="M1200 0L0 0 598.97 114.72 1200 0z" class="shape-fill bg-bgDark1 fill-bgDark1"
          ></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-fade-in {
    opacity: 0;
    transform: translateY(10px);
    animation: heroFadeIn 0.5s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
