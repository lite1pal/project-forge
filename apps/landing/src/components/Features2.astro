---
import { Image } from 'astro:assets';
import feature5 from '../assets/images/feature5.jpg';
import feature6 from '../assets/images/feature6.jpg';
import CheckArrowIcon from '../assets/icons/CheckArrowIcon.astro';
---

<section class="bg-bgDark2 mt-12 mb-12 w-full pt-4 sm:mt-24 lg:my-20 lg:mb-24" id="workflow">
  <div class="fade-in">
    <div
      class="mx-auto flex w-11/12 flex-wrap items-center md:pl-4 xl:w-[81.25rem] xl:pr-16 xl:pl-16 2xl:w-[90.625rem]"
    >
      <div
        class="order-last mx-auto flex w-11/12 flex-wrap justify-center sm:w-3/4 sm:pr-8 lg:order-first lg:-mx-4 lg:w-1/2"
      >
        <div class="mb-8 flex w-full flex-col justify-center px-2 md:pl-8 lg:mb-0 lg:pl-16">
          <div class="mb-4 rounded py-3 md:pr-20 md:pl-3 lg:pr-12">
            <div class="relative">
              <Image
                src={feature5}
                alt="Elioric CLI planning preview"
                class="image-border rounded-xl"
                loading="eager"
                decoding="sync"
              />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
          <div class="rounded py-3 md:pr-2 md:pl-20 lg:pl-12">
            <div class="relative">
              <Image
                src={feature6}
                alt="Elioric generated module preview"
                class="image-border rounded-xl"
                loading="eager"
                decoding="sync"
              />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="mb-12 w-full lg:mb-0 lg:w-1/2 xl:pl-8">
        <div class="lg:w-unset mx-auto w-11/12 sm:w-4/5 md:w-3/4 lg:mx-auto">
          <span class="block-subtitle">Terminal-first workflow</span>
          <h2 class="block-big-title mt-6 mb-8 text-4xl lg:text-5xl">
            Go from idea to working feature
          </h2>
          <p class="text-secondaryText mb-12 leading-loose">
            Plan a feature, preview the generated code, install it into your platform, generate the
            migration, and verify everything before shipping.
          </p>
          <ul class="text-primaryText mb-6">
            <li class="mb-4 flex">
              <CheckArrowIcon />
              <span>Define a resource spec entirely from the CLI</span>
            </li>
            <li class="mb-4 flex">
              <CheckArrowIcon />
              <span>Preview generated code before touching runtime source</span>
            </li>
            <li class="mb-4 flex">
              <CheckArrowIcon />
              <span>Install into the reference platform through bounded patch seams</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
