---
import TailcastLogo from '../assets/logos/TailcastLogo.astro';

const footerData = [
  {
    title: 'Framework',
    items: [
      { label: 'Why Project Anvil', href: '/#why' },
      { label: 'Workflow', href: '/#workflow' },
      { label: 'Proof', href: '/#proof' },
      { label: 'FAQ', href: '/#faq' },
    ],
  },
  {
    title: 'Repository',
    items: [
      { label: 'README', href: 'https://github.com/denistarasenko/auditrail#readme' },
      {
        label: 'Architecture docs',
        href: 'https://github.com/denistarasenko/auditrail/tree/main/docs',
      },
      { label: 'Task tracker', href: 'https://github.com/denistarasenko/auditrail/tree/main/tasks' },
      {
        label: 'Reference product',
        href: 'https://github.com/denistarasenko/auditrail/tree/main/apps',
      },
    ],
  },
  {
    title: 'Status',
    items: [
      { label: 'Framework in progress', href: '/#faq' },
      { label: 'AuditTrail proves the seams', href: '/#proof' },
      { label: 'Landing based on Tailcast', href: 'https://github.com/matt765/Tailcast' },
    ],
  },
];
---

<footer aria-label="Site footer">
  <div class="bg-bgDark1 radius-for-skewed pt-10 pb-16 lg:pt-16 lg:pb-20">
    <div class="content-container">
      <div class="flex flex-wrap">
        <div
          class="order-1 mb-16 flex w-full flex-nowrap justify-center gap-x-8 sm:flex-wrap sm:gap-x-16 lg:order-2 lg:mb-0 lg:w-2/3 lg:justify-end"
        >
          {
            footerData.map((section, i) => (
              <div
                class:list={[
                  'text-center sm:mb-16 sm:w-auto md:mb-0 lg:text-left',
                  i === 2 ? 'hidden sm:block' : 'w-1/2 sm:w-auto',
                ]}
              >
                <h3 class="text-primaryText mb-5 text-lg font-bold">{section.title}</h3>
                <ul>
                  {section.items.map((item) => (
                    <li class="mb-3">
                      <a
                        class="cursor-pointer text-sm text-gray-400 hover:text-gray-300"
                        href={item.href}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
        <div class="order-2 w-full lg:order-1 lg:mb-0 lg:w-1/3">
          <div class="flex grow basis-0 items-center justify-center lg:justify-start">
            <div class="mr-2 text-6xl text-white">
              <TailcastLogo />
            </div>
            <div class="font-['Inter'] text-xl font-bold text-white">Project Anvil</div>
          </div>
          <p
            class="mx-auto mt-4 mb-6 text-center leading-loose text-gray-400 sm:w-[22rem] lg:mx-0 lg:w-[20rem] lg:text-left xl:w-[24rem]"
          >
            Project Anvil is an AI-native framework for building production-ready platforms. This
            landing adapts the MIT-licensed <a
              href="https://github.com/matt765/Tailcast"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-100"
              aria-label="Tailcast repository (opens in new tab)">Tailcast</a
            >
            Astro theme for framework-focused public messaging.
          </p>
          <div class="flex justify-center lg:justify-start">
            <a
              href="https://github.com/denistarasenko/auditrail"
              target="_blank"
              rel="noopener noreferrer"
              class="outlined-button border-mainBorderSubtle mr-2 inline-block cursor-pointer px-4 py-2 text-sm text-white"
              aria-label="Project Anvil repository"
            >
              Repository
            </a>
            <a
              href="https://github.com/denistarasenko/auditrail/tree/main/docs"
              target="_blank"
              rel="noopener noreferrer"
              class="outlined-button border-mainBorderSubtle mr-2 inline-block cursor-pointer px-4 py-2 text-sm text-white"
              aria-label="Project Anvil documentation"
            >
              Docs
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
