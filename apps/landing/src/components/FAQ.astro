---
const FAQData = [
  {
    question: 'Is Project Anvil a generic starter kit already?',
    answer:
      'No. The repository is still a framework-in-progress plus the AuditTrail reference product. The point is to separate platform from product cleanly enough that new products become cheap to build without pretending the multi-product runtime is finished.',
  },
  {
    question: 'What can I create with the terminal-first workflow today?',
    answer:
      'You can initialize a resource spec, plan it, generate preview files, install the supported slice into the repo, generate the migration, and verify the result through the existing quality gates. The current safe path is intentionally narrow and explicit.',
  },
  {
    question: 'Why keep AuditTrail inside the same repository?',
    answer:
      'Because the framework needs a real product to prove its abstractions. AuditTrail exercises auth, projects, API keys, billing, webhooks, jobs, ingestion, and investigations, which keeps the platform seams honest.',
  },
  {
    question: 'What is still missing before this becomes a true multi-product platform?',
    answer:
      'The main remaining work is runtime product installation and composition. Product manifests now exist, but installed-product state, registry-driven composition, product-aware shell and API wiring, and product-owned billing or webhook boundaries still need to land.',
  },
];
---

<section class="relative -mt-8 pt-12 pb-16 sm:mt-0 sm:pt-16" id="faq">
  <div class="fade-in">
    <div class="relative z-10 container mx-auto w-11/12 px-2 sm:w-full sm:px-8 lg:px-4">
      <div class="mx-auto md:max-w-4xl">
        <p class="block-subtitle mb-7 text-center">Questions worth answering</p>
        <h2 class="block-big-title mb-16 text-center">Frequently Asked Questions</h2>
        <div class="-m-1 mb-11 flex flex-wrap">
          {
            FAQData.map((item, index) => (
              <div class="w-full p-1">
                <div
                  class="faq-box card mb-4 cursor-pointer rounded-3xl px-5 py-5 sm:px-8 sm:py-6"
                  data-open={index === 0 ? 'true' : 'false'}
                >
                  <button
                    type="button"
                    class="flex w-full cursor-pointer items-center justify-between bg-transparent text-left"
                    aria-expanded={index === 0 ? 'true' : 'false'}
                    aria-controls={`faq-panel-${index}`}
                    id={`faq-header-${index}`}
                  >
                    <h3 class="content-title">{item.question}</h3>
                    <svg
                      width="28px"
                      height="30px"
                      viewBox="0 0 20 20"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      class={`faq-chevron text-secondaryColor ml-4 shrink-0 transition-transform duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] ${index === 0 ? 'rotate-[180deg]' : 'rotate-[270deg]'}`}
                      aria-hidden="true"
                    >
                      <path
                        d="M4.16732 12.5L10.0007 6.66667L15.834 12.5"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </button>
                  <div
                    class={`faq-answer-grid ${index === 0 ? 'faq-open' : ''}`}
                    id={`faq-panel-${index}`}
                    role="region"
                    aria-labelledby={`faq-header-${index}`}
                  >
                    <div class="faq-answer-inner">
                      <p class="text-secondaryText pt-4">{item.answer}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-answer-grid {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 200ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 150ms ease;
  }
  .faq-answer-grid.faq-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  .faq-answer-inner {
    overflow: hidden;
    min-height: 0;
  }
</style>

<script>
  const initFaq = () => {
    document.querySelectorAll('.faq-box').forEach((box) => {
      const btn = box.querySelector('button');
      box.addEventListener('click', () => {
        const answerGrid = box.querySelector('.faq-answer-grid');
        const chevron = box.querySelector('.faq-chevron');
        const isOpen = box.getAttribute('data-open') === 'true';

        if (isOpen) {
          answerGrid?.classList.remove('faq-open');
          chevron?.classList.remove('rotate-[180deg]');
          chevron?.classList.add('rotate-[270deg]');
          box.setAttribute('data-open', 'false');
          btn?.setAttribute('aria-expanded', 'false');
        } else {
          answerGrid?.classList.add('faq-open');
          chevron?.classList.add('rotate-[180deg]');
          chevron?.classList.remove('rotate-[270deg]');
          box.setAttribute('data-open', 'true');
          btn?.setAttribute('aria-expanded', 'true');
        }
      });
    });
  };

  document.addEventListener('astro:page-load', initFaq);
</script>
