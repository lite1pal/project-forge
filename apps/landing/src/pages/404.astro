---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page not found - Project Anvil" noindex>
  <Navbar />
  <section
    class="bg-bgDark1 flex min-h-screen flex-col items-center justify-center px-4 text-center"
  >
    <h1 class="text-primaryColor mb-4 text-8xl font-bold sm:text-9xl">404</h1>
    <h2 class="text-primaryText mb-4 text-2xl font-bold sm:text-3xl">Page not found</h2>
    <p class="text-secondaryText mb-10 max-w-md">
      The page you requested is not part of the current Project Anvil landing.
    </p>
    <a href="/" class="contained-button px-8 py-3 text-lg"> Back to Home </a>
  </section>
  <Footer />
</Layout>
